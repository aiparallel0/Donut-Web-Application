# Environment Variables for DONUT Receipt Parser
# Copy this file to .env and customize as needed

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================
# Model to use (default: naver-clova-ix/donut-base-finetuned-cord-v2)
DONUT_MODEL_NAME=naver-clova-ix/donut-base-finetuned-cord-v2

# Device to use: cpu, cuda, or auto
DONUT_DEVICE=auto

# HuggingFace token (only needed for gated models)
# Get yours at: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_your_token_here

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Enable debug mode (true/false)
DONUT_DEBUG=false

# Enable API endpoints (true/false)
DONUT_API_ENABLED=true

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Gradio web interface
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false

# REST API
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================
# Batch size for parallel processing
BATCH_SIZE=4

# Number of worker threads
NUM_WORKERS=4

# Clear GPU cache after inference (true/false)
CLEAR_CACHE_AFTER_INFERENCE=true

# ============================================================================
# PATHS (optional overrides)
# ============================================================================
# CACHE_DIR=./models
# OUTPUT_DIR=./data/output
# LOG_DIR=./logs

# ============================================================================
# LOGGING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log to console (true/false)
LOG_TO_CONSOLE=true

# ============================================================================
# ADVANCED SETTINGS
# ============================================================================
# Maximum image size (width,height)
# MAX_IMAGE_SIZE=1280,960

# Generation timeout in seconds (0 = no timeout)
# GENERATION_TIMEOUT=60

# Maximum batch size
# MAX_BATCH_SIZE=8
